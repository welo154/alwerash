# =============================================================================
# Database (Supabase)
# =============================================================================
# Copy values from Supabase → Project Settings → Database → Connection string.
#
# IPv4 networks: use the "Session pooler" string (host like aws-0-REGION.pooler.supabase.com,
# port 5432, user postgres.PROJECT_REF). Do not use the "Transaction pooler" :6543 URL unless
# you know you need it; it often fails from home/office IPv4 setups.
#
# "Direct connection" (db.PROJECT_REF.supabase.co:5432, user postgres) may be labeled
# "Not IPv4 compatible" — use for DIRECT_URL only if migrations work from your network,
# or run migrations from Supabase SQL / a host with IPv6 / enable Supabase IPv4 add-on.
#
# URL-encode special characters in the password (e.g. $ → %24).
#
# Runtime (Prisma queries) — Session pooler example:
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"
#
# Migrations (Prisma migrate) — Direct host example:
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
#
# Replace PROJECT_REF, REGION, and YOUR_PASSWORD with your Supabase values.

# =============================================================================
# Auth.js / NextAuth
# =============================================================================
# Generate with: openssl rand -base64 32  (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET="replace-with-generated-secret"

# Set to "true" in development; required for auth callbacks to work
AUTH_TRUST_HOST="true"

# App URL — must match the origin you open in the browser (default `npm run dev` uses port 3002)
AUTH_URL="http://localhost:3002"

# Legacy names (Auth.js v4 / NextAuth); optional if you use AUTH_* above
# NEXTAUTH_SECRET="same-as-AUTH_SECRET"
# NEXTAUTH_URL="http://localhost:3002"

# =============================================================================
# Admin seed (for: npx prisma db seed)
# =============================================================================
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-secure-password"
ADMIN_NAME="Platform Admin"

# =============================================================================
# Mux API (video upload & HLS playback)
# =============================================================================
# From Mux dashboard: Settings → Access Tokens
MUX_TOKEN_ID="replace-with-mux-token-id"
MUX_TOKEN_SECRET="replace-with-mux-token-secret"

# Mux webhook signing secret (from webhook config in Mux dashboard)
MUX_WEBHOOK_SECRET="replace-with-webhook-secret"

# Mux signing keypair (optional; only for signed playback)
MUX_SIGNING_KEY_ID="replace-with-signing-key-id"
# PEM: one line with \n for newlines
MUX_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Playback token TTL (e.g. 2h)
MUX_PLAYBACK_TOKEN_TTL="2h"

# CORS origin for direct upload (match your dev server origin, e.g. localhost:3002)
MUX_UPLOAD_CORS_ORIGIN="http://localhost:3002"

# =============================================================================
# Email verification (Resend)
# =============================================================================
# From https://resend.com/api-keys
RESEND_API_KEY="replace-with-resend-api-key"
# Sender for verification emails. Use "onboarding@resend.dev" for testing; verify your domain in production.
RESEND_FROM_EMAIL="Ahwaleed154@gmail.com"
